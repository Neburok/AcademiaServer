# ============================================================
#  AcademiaServer — configuración de entorno
#  Copia este archivo como .env y rellena los valores.
#  El .env nunca se versiona (está en .gitignore).
# ============================================================


# ------------------------------------------------------------
#  Base de datos
# ------------------------------------------------------------
DB_PATH=academia.db


# ------------------------------------------------------------
#  Telegram
#  Obtén el token con @BotFather en Telegram.
#  El CHAT_ID es el ID numérico de tu chat personal con el bot.
# ------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=


# ------------------------------------------------------------
#  IA — Proveedor
#  Opciones: ollama | cloud | hybrid
#
#  ollama  → solo modelo local (recomendado en rubenpc con GPU)
#  cloud   → solo OpenAI
#  hybrid  → Ollama primero, OpenAI como fallback si falla
# ------------------------------------------------------------
AI_PROVIDER=ollama


# ------------------------------------------------------------
#  IA — Ollama (modelo local)
#
#  En rubenpc (servidor):
#    OLLAMA_BASE_URL=http://localhost:11434
#
#  En otro equipo que accede a rubenpc vía Tailscale:
#    OLLAMA_BASE_URL=http://<IP-Tailscale-de-rubenpc>:11434
#    (ver IP en rubenpc con: tailscale ip)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

AI_TIMEOUT_SECONDS=25
AI_MAX_RETRIES=2
AI_HTTP_MAX_RETRIES=2
AI_HTTP_RETRY_DELAY_SECONDS=1


# ------------------------------------------------------------
#  IA — OpenAI (fallback cloud, opcional)
#  Solo necesario si AI_PROVIDER=cloud o hybrid.
#  AI_CLOUD_ALLOW_SENSITIVE=false evita enviar mensajes
#  sensibles a la nube (recomendado).
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
AI_ENABLE_CLOUD_FALLBACK=false
AI_CLOUD_ALLOW_SENSITIVE=false


# ------------------------------------------------------------
#  Servidor API (FastAPI / Uvicorn)
#
#  SERVER_HOST=0.0.0.0 hace que la API sea accesible desde
#  todos los dispositivos de la red Tailscale.
#  Cambia a 127.0.0.1 si solo quieres acceso local.
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


# ------------------------------------------------------------
#  Scheduler de recordatorios
#  SCHEDULER_INTERVAL_SECONDS: frecuencia de revisión en segundos
#  REMINDER_MAX_RETRIES: intentos antes de descartar un envío
# ------------------------------------------------------------
SCHEDULER_INTERVAL_SECONDS=60
REMINDER_MAX_RETRIES=3
REMINDER_RETRY_DELAY_SECONDS=5


# ------------------------------------------------------------
#  Logs
# ------------------------------------------------------------
LOG_DIR=logs
