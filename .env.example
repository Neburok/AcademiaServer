# ============================================================
#  AcademiaServer — configuración de entorno
#  Copia este archivo como .env y rellena los valores.
#  El .env nunca se versiona (está en .gitignore).
# ============================================================


# ------------------------------------------------------------
#  Base de datos
# ------------------------------------------------------------
DB_PATH=academia.db


# ------------------------------------------------------------
#  Telegram
#  Obtén el token con @BotFather en Telegram.
#  El CHAT_ID es el ID numérico de tu chat personal con el bot.
# ------------------------------------------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=


# ------------------------------------------------------------
#  IA — Proveedor
#  Opciones: ollama | cloud | hybrid
#
#  ollama  → solo modelo local (recomendado en rubenpc con GPU)
#  cloud   → solo proveedor cloud (ver AI_CLOUD_PROVIDER)
#  hybrid  → Ollama primero, proveedor cloud como fallback
# ------------------------------------------------------------
AI_PROVIDER=ollama


# ------------------------------------------------------------
#  IA — Ollama (modelo local)
#
#  En rubenpc (servidor):
#    OLLAMA_BASE_URL=http://localhost:11434
#
#  En otro equipo que accede a rubenpc vía Tailscale:
#    OLLAMA_BASE_URL=http://<IP-Tailscale-de-rubenpc>:11434
#    (ver IP en rubenpc con: tailscale ip)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

AI_TIMEOUT_SECONDS=25
AI_MAX_RETRIES=2
AI_HTTP_MAX_RETRIES=2
AI_HTTP_RETRY_DELAY_SECONDS=1


# ------------------------------------------------------------
#  IA — Proveedor cloud (openai | claude)
#  Controla cuál servicio se usa en modo 'cloud' y como
#  fallback en modo 'hybrid'. Por defecto: openai.
# ------------------------------------------------------------
AI_CLOUD_PROVIDER=claude
AI_ENABLE_CLOUD_FALLBACK=false
AI_CLOUD_ALLOW_SENSITIVE=false


# ------------------------------------------------------------
#  IA — Anthropic Claude API (si AI_CLOUD_PROVIDER=claude)
#  Obtén tu API key en: https://console.anthropic.com/
#  Modelos recomendados:
#    claude-3-5-sonnet-20241022  (calidad, análisis complejo)
#    claude-3-5-haiku-20241022   (velocidad y menor costo)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=1024


# ------------------------------------------------------------
#  IA — OpenAI (si AI_CLOUD_PROVIDER=openai)
#  Solo necesario si prefieres OpenAI como proveedor cloud.
# ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini


# ------------------------------------------------------------
#  Servidor API (FastAPI / Uvicorn)
#
#  SERVER_HOST=0.0.0.0 hace que la API sea accesible desde
#  todos los dispositivos de la red Tailscale.
#  Cambia a 127.0.0.1 si solo quieres acceso local.
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


# ------------------------------------------------------------
#  Scheduler de recordatorios
#  SCHEDULER_INTERVAL_SECONDS: frecuencia de revisión en segundos
#  REMINDER_MAX_RETRIES: intentos antes de descartar un envío
# ------------------------------------------------------------
SCHEDULER_INTERVAL_SECONDS=60
REMINDER_MAX_RETRIES=3
REMINDER_RETRY_DELAY_SECONDS=5


# ------------------------------------------------------------
#  Whisper (transcripción de notas de voz)
#
#  Patrón local → cloud fallback:
#    1. faster-whisper (local, requiere ffmpeg en PATH)
#    2. OpenAI Whisper API (usa OPENAI_API_KEY)
#
#  Para GPU en rubenpc:
#    WHISPER_DEVICE=cuda
#    WHISPER_COMPUTE_TYPE=float16
#
#  Instalar ffmpeg en Windows:
#    winget install Gyan.FFmpeg
# ------------------------------------------------------------
WHISPER_MODEL=small
WHISPER_LANGUAGE=es
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_TIMEOUT=60


# ------------------------------------------------------------
#  Logs
# ------------------------------------------------------------
LOG_DIR=logs


# ------------------------------------------------------------
#  Documentos generados por agentes educativos (Fase 4.1)
#  Directorio donde se guardan los archivos .md y .tex que
#  producen PlanningAgent, ScriptAgent y SlidesAgent.
#  Se envían al Profesor como attachment de Telegram y quedan
#  disponibles para compilación con pdflatex (para .tex Beamer).
# ------------------------------------------------------------
OUTPUTS_DIR=outputs


# ------------------------------------------------------------
#  Plantillas LaTeX UTEQ (Fase 4.2-B)
#  Directorio con plantillas externas para documentos académicos.
#  Si templates/beamer/preamble.tex existe, MarkdownToBeamer
#  lo usa en lugar del preamble hardcodeado (identidad UTEQ).
#  Copia aquí tus plantillas .tex UTEQ reales sin tocar código.
#  Ver: templates/README.md para instrucciones de personalización.
# ------------------------------------------------------------
TEMPLATES_DIR=templates
